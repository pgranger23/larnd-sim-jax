 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Plot Gradient Scan Results\n",
    "\n",
    "This notebook replicates the features of `optimize/analysis_scripts/plot_scan.py` for interactive use. It allows you to visualize gradient and loss scans, sub-loss terms, and computation time from `.pkl` result files."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import numpy as np\n",
    "import pickle\n",
    "import matplotlib.pyplot as plt\n",
    "import glob\n",
    "import os\n",
    "from pathlib import Path\n",
    "import logging\n",
    "\n",
    "%matplotlib inline\n",
    "\n",
    "logging.basicConfig()\n",
    "logger = logging.getLogger(__name__)\n",
    "logger.setLevel(logging.INFO)\n",
    "plt.rcParams['font.size'] = 12\n",
    "plt.rcParams['figure.figsize'] = (10, 6)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Configuration\n",
    "\n",
    "Set the input and output directories here."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "INPUT_DIR = \"scan_results\"  # Path to the input dir with scan result files\n",
    "OUTPUT_DIR = \"scan_plots\"   # Path to the output dir for saving plots\n",
    "\n",
    "# Create output directory if it doesn't exist\n",
    "output_path = Path(OUTPUT_DIR)\n",
    "output_path.mkdir(parents=True, exist_ok=True)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Helper Functions\n",
    "\n",
    "These functions are ported from `plot_scan.py`."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def load_scan_file(fname):\n",
    "    \"\"\"Load a scan pickle file and validate it.\"\"\"\n",
    "    with open(fname, 'rb') as f:\n",
    "        results = pickle.load(f)\n",
    "    \n",
    "    if 'config' not in results:\n",
    "        raise ValueError(f\"No config found in {fname}\")\n",
    "    \n",
    "    config = results['config']\n",
    "    if not hasattr(config, 'fit_type') or config.fit_type != 'scan':\n",
    "        # Some older files might not have fit_type='scan' but are still valid scans\n",
    "        logger.warning(f\"Expected fit_type='scan', found {getattr(config, 'fit_type', 'unknown')} in {fname}\")\n",
    "    \n",
    "    # Extract parameter names\n",
    "    params = [key.replace('_grad', '') for key in results.keys() if '_grad' in key]\n",
    "    \n",
    "    return results, params, config\n",
    "\n",
    "\n",
    "def extract_param_from_filename(fname, params):\n",
    "    \"\"\"\n",
    "    Extract parameter name and batch number from filename.\n",
    "    Expected format: history_{param}_batch{N}_{label}.pkl\n",
    "    \"\"\"\n",
    "    basename = os.path.basename(fname)\n",
    "    if not basename.startswith('history_'):\n",
    "        # Try to find any param in the filename\n",
    "        for p in params:\n",
    "            if p in basename:\n",
    "                return p, None\n",
    "        return None, None\n",
    "    \n",
    "    parts = basename.split('_')\n",
    "    \n",
    "    # Try to match parameter name (can be multi-word like \"long_diff\")\n",
    "    for i in range(1, len(parts)):\n",
    "        potential_param = '_'.join(parts[1:i+1])\n",
    "        if potential_param in params:\n",
    "            # Found the parameter, now look for batch number\n",
    "            batch_num = None\n",
    "            for j in range(i+1, len(parts)):\n",
    "                if parts[j].startswith('batch'):\n",
    "                    try:\n",
    "                        batch_num = int(parts[j].replace('batch', ''))\n",
    "                    except ValueError:\n",
    "                        pass\n",
    "            return potential_param, batch_num\n",
    "    \n",
    "    return None, None\n",
    "\n",
    "\n",
    "def extract_scan_data(results, params, config, fname):\n",
    "    \"\"\"\n",
    "    Extract scan data for the parameter specified in filename.\n",
    "    \"\"\"\n",
    "    nparams = len(params)\n",
    "    nb_iter = getattr(config, 'iterations', 0)\n",
    "    if nb_iter == 0:\n",
    "        # Try to infer nb_iter from data if not in config\n",
    "        total_points = len(results[\"losses_iter\"])\n",
    "        if nparams == 1:\n",
    "            nb_iter = total_points\n",
    "        else:\n",
    "            # This is ambiguous without knowing n_scans\n",
    "            nb_iter = total_points \n",
    "            \n",
    "    total_points = len(results[\"losses_iter\"])\n",
    "    \n",
    "    # Extract parameter name and batch number from filename\n",
    "    param_name, batch_num = extract_param_from_filename(fname, params)\n",
    "    \n",
    "    if param_name is None:\n",
    "        if len(params) == 1:\n",
    "            param_name = params[0]\n",
    "        else:\n",
    "            raise ValueError(f\"Could not extract parameter name from filename: {fname}\")\n",
    "    \n",
    "    if param_name not in params:\n",
    "        raise ValueError(f\"Parameter {param_name} not found in file {fname}\")\n",
    "    \n",
    "    param_idx = params.index(param_name)\n",
    "    \n",
    "    # Validate data layout\n",
    "    if nb_iter > 0 and total_points % nb_iter != 0:\n",
    "        logger.warning(f\"Total points {total_points} not divisible by iterations {nb_iter}\")\n",
    "        n_scans = 1\n",
    "        nb_iter = total_points\n",
    "    else:\n",
    "        n_scans = total_points // nb_iter if nb_iter > 0 else 1\n",
    "    \n",
    "    # Extract data for all batches up to batch_num\n",
    "    if batch_num is None:\n",
    "        num_batches = (n_scans + nparams - 1) // nparams if nparams > 0 else 1\n",
    "    else:\n",
    "        num_batches = batch_num + 1\n",
    "    \n",
    "    param_values_list = []\n",
    "    grad_list = []\n",
    "    loss_list = []\n",
    "    aux_data = {}  \n",
    "    \n",
    "    for b in range(num_batches):\n",
    "        scan_idx = b * nparams + param_idx\n",
    "        \n",
    "        if scan_idx >= n_scans:\n",
    "            break\n",
    "        \n",
    "        start_iter = 1 + scan_idx * nb_iter\n",
    "        end_iter = start_iter + nb_iter\n",
    "        start_data = scan_idx * nb_iter\n",
    "        end_data = start_data + nb_iter\n",
    "        \n",
    "        # Check bounds\n",
    "        if f\"{param_name}_iter\" in results and end_iter <= len(results[f\"{param_name}_iter\"]):\n",
    "            param_values_list.append(results[f\"{param_name}_iter\"][start_iter:end_iter])\n",
    "        else:\n",
    "            # Fallback for different indexing\n",
    "            param_values_list.append(results[f\"{param_name}_iter\"][start_data:end_data])\n",
    "            \n",
    "        grad_list.append(results[f\"{param_name}_grad\"][start_data:end_data])\n",
    "        loss_list.append(results[\"losses_iter\"][start_data:end_data])\n",
    "        \n",
    "        if 'aux_iter' in results and len(results['aux_iter']) > 0:\n",
    "            aux_slice = results['aux_iter'][start_data:end_data]\n",
    "            if b == 0 and len(aux_slice) > 0:\n",
    "                first_entry = aux_slice[0] if isinstance(aux_slice[0], dict) else {}\n",
    "                for key in first_entry.keys():\n",
    "                    aux_data[key] = []\n",
    "            \n",
    "            for key in aux_data.keys():\n",
    "                batch_values = []\n",
    "                for entry in aux_slice:\n",
    "                    if isinstance(entry, dict) and key in entry:\n",
    "                        val = entry[key]\n",
    "                        batch_values.append(float(val) if isinstance(val, (float, int)) else np.nan)\n",
    "                    else:\n",
    "                        batch_values.append(np.nan)\n",
    "                aux_data[key].append(batch_values)\n",
    "    \n",
    "    param_values = np.array(param_values_list)\n",
    "    gradients = np.array(grad_list)\n",
    "    losses = np.array(loss_list)\n",
    "    \n",
    "    for key in aux_data.keys():\n",
    "        aux_data[key] = np.array(aux_data[key])\n",
    "    \n",
    "    target = results.get(f\"{param_name}_target\", [None])[0] if f\"{param_name}_target\" in results else None\n",
    "    \n",
    "    return param_values, gradients, losses, aux_data, param_name, target\n",
    "\n",
    "\n",
    "def make_title(config):\n",
    "    \"\"\"Generate title string from config.\"\"\"\n",
    "    batch_size = getattr(config, 'max_batch_len', 0)\n",
    "    noise = not getattr(config, 'no_noise', False)\n",
    "    seed_strategy = getattr(config, 'sim_seed_strategy', 'unknown')\n",
    "    sampling = getattr(config, 'electron_sampling_resolution', 0) * 1e4\n",
    "    \n",
    "    return (f\"{batch_size:.0f}cm batches ; Noise: {'on' if noise else 'off'} ; \"\n",
    "            f\"Random strategy: {seed_strategy} ; Sampling resolution: {sampling:.0f}um\")"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Plotting Functions"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "def plot_gradient_scan(fname, ax=None, plot_all=False):\n",
    "    results, params, config = load_scan_file(fname)\n",
    "    param_values, gradients, losses, aux_data, param_name, target = extract_scan_data(\n",
    "        results, params, config, fname\n",
    "    )\n",
    "    \n",
    "    if ax is None:\n",
    "        fig, ax = plt.subplots(1, 1, figsize=(10, 6))\n",
    "    \n",
    "    if not plot_all:\n",
    "        param_values_plot = np.nanmean(param_values, axis=0)\n",
    "        gradients_plot = np.nanmean(gradients, axis=0)\n",
    "        losses_plot = np.nanmean(losses, axis=0)\n",
    "        alpha = 1.0\n",
    "    else:\n",
    "        param_values_plot = param_values.T\n",
    "        gradients_plot = gradients.T\n",
    "        losses_plot = losses.T\n",
    "        alpha = 0.3\n",
    "    \n",
    "    # Plot gradient on primary axis\n",
    "    l1 = ax.plot(param_values_plot, gradients_plot, color='blue', label='gradient', alpha=alpha)\n",
    "    ax.set_xlabel(param_name)\n",
    "    ax.set_ylabel('Gradient', color='blue')\n",
    "    ax.tick_params(axis='y', colors='blue')\n",
    "    \n",
    "    # Plot loss on secondary axis\n",
    "    ax2 = ax.twinx()\n",
    "    l2 = ax2.plot(param_values_plot, losses_plot, color='green', label='loss', alpha=alpha)\n",
    "    ax2.set_ylabel('Loss', color='green')\n",
    "    ax2.tick_params(axis='y', colors='green')\n",
    "    \n",
    "    l3 = ax.axhline(0, color='red', linestyle='--', linewidth=1, alpha=0.7, label='zero gradient')\n",
    "    \n",
    "    lines = l1[:1] + l2[:1] + [l3]\n",
    "    if target is not None:\n",
    "        l4 = ax.axvline(target, color='red', linestyle='--', linewidth=1, alpha=0.7, label='target')\n",
    "        lines.append(l4)\n",
    "    \n",
    "    labels = [l.get_label() for l in lines]\n",
    "    ax2.legend(lines, labels, loc='best')\n",
    "    \n",
    "    ax.set_title(f\"Gradient scan for {param_name}\")\n",
    "    ax.get_figure().suptitle(make_title(config), y=1.02)\n",
    "    ax.grid(True, alpha=0.3)\n",
    "\n",
    "\n",
    "def plot_subloss_scan(fname, ax=None, plot_all=False):\n",
    "    results, params, config = load_scan_file(fname)\n",
    "    param_values, gradients, losses, aux_data, param_name, target = extract_scan_data(\n",
    "        results, params, config, fname\n",
    "    )\n",
    "    \n",
    "    if not aux_data:\n",
    "        if ax is not None:\n",
    "            ax.text(0.5, 0.5, 'No auxiliary data available', ha='center', va='center', transform=ax.transAxes)\n",
    "            ax.axis('off')\n",
    "        return\n",
    "    \n",
    "    if ax is None:\n",
    "        fig, ax = plt.subplots(1, 1, figsize=(10, 6))\n",
    "    \n",
    "    if not plot_all:\n",
    "        param_values_plot = np.nanmean(param_values, axis=0)\n",
    "    else:\n",
    "        param_values_plot = param_values.T\n",
    "    \n",
    "    colors = ['purple', 'orange', 'brown', 'pink', 'gray', 'cyan']\n",
    "    for idx, (key, values) in enumerate(aux_data.items()):\n",
    "        if not plot_all:\n",
    "            values_plot = np.nanmean(values, axis=0)\n",
    "            alpha = 1.0\n",
    "        else:\n",
    "            values_plot = values.T\n",
    "            alpha = 0.3\n",
    "        \n",
    "        color = colors[idx % len(colors)]\n",
    "        ax.plot(param_values_plot, values_plot, color=color, label=key, alpha=alpha)\n",
    "    \n",
    "    ax.set_xlabel(param_name)\n",
    "    ax.set_ylabel('Sub-loss values')\n",
    "    if target is not None:\n",
    "        ax.axvline(target, color='red', linestyle='--', linewidth=1, alpha=0.7, label='target')\n",
    "    \n",
    "    ax.legend(loc='best')\n",
    "    ax.set_title(f\"Sub-loss terms for {param_name}\")\n",
    "    ax.get_figure().suptitle(make_title(config), y=1.02)\n",
    "    ax.grid(True, alpha=0.3)\n",
    "\n",
    "\n",
    "def plot_time(fname, ax=None):\n",
    "    results, params, config = load_scan_file(fname)\n",
    "    if ax is None:\n",
    "        fig, ax = plt.subplots(1, 1, figsize=(10, 6))\n",
    "    \n",
    "    time = np.array(results[\"step_time\"])\n",
    "    ax.plot(time, label='Time')\n",
    "    ax.set_ylabel('Time (s)')\n",
    "    ax.set_xlabel('Iteration')\n",
    "    ax.set_title(f\"Time per iteration\")\n",
    "    ax.get_figure().suptitle(make_title(config), y=1.02)\n",
    "    ax.grid(True, alpha=0.3)"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Generate Summary Plots\n",
    "\n",
    "This cell generates the summary plots for all files in the input directory, similar to the `main()` function in the script."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "input_path = Path(INPUT_DIR)\n",
    "list_of_files = sorted(input_path.glob('*.pkl'))\n",
    "\n",
    "if not list_of_files:\n",
    "    print(f\"No .pkl files found in {INPUT_DIR}\")\n",
    "else:\n",
    "    nparams = len(list_of_files)\n",
    "    ncols = min(3, nparams)\n",
    "    nrows = (nparams + ncols - 1) // ncols\n",
    "    \n",
    "    print(f\"Found {nparams} scan files. Generating summary plots...\")\n",
    "    \n",
    "    # 1. Gradient and Loss (Averaged)\n",
    "    fig, axs = plt.subplots(nrows, ncols, figsize=(6*ncols, 5*nrows), squeeze=False)\n",
    "    for i, fname in enumerate(list_of_files):\n",
    "        plot_gradient_scan(str(fname), axs[i // ncols, i % ncols], plot_all=False)\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "    \n",
    "    # 2. Sub-losses (Averaged)\n",
    "    fig, axs = plt.subplots(nrows, ncols, figsize=(6*ncols, 5*nrows), squeeze=False)\n",
    "    for i, fname in enumerate(list_of_files):\n",
    "        plot_subloss_scan(str(fname), axs[i // ncols, i % ncols], plot_all=False)\n",
    "    plt.tight_layout()\n",
    "    plt.show()\n",
    "    \n",
    "    # 3. Step Time\n",
    "    fig, axs = plt.subplots(nrows, ncols, figsize=(6*ncols, 5*nrows), squeeze=False)\n",
    "    for i, fname in enumerate(list_of_files):\n",
    "        plot_time(str(fname), axs[i // ncols, i % ncols])\n",
    "    plt.tight_layout()\n",
    "    plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "## Detailed View (Single File)\n",
    "\n",
    "Select a file to see individual batches."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "if list_of_files:\n",
    "    # Change the index to select a different file\n",
    "    file_to_plot = str(list_of_files[0])\n",
    "    print(f\"Plotting detailed view for: {file_to_plot}\")\n",
    "    \n",
    "    fig, ax = plt.subplots(1, 1, figsize=(12, 6))\n",
    "    plot_gradient_scan(file_to_plot, ax=ax, plot_all=True)\n",
    "    plt.show()\n",
    "    \n",
    "    fig, ax = plt.subplots(1, 1, figsize=(12, 6))\n",
    "    plot_subloss_scan(file_to_plot, ax=ax, plot_all=True)\n",
    "    plt.show()"
   ]
  }
 ],
